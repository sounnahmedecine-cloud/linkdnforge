# Example Environment Variables
# Copy this to .env.local and fill in your values

# Next.js
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development

# Claude API (required)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Firebase Configuration (required)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your-app-id:web:your-id

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Admin SDK (Server-side only - NEVER commit)
# Get from: Firebase Console → Project Settings → Service Accounts
# Copy entire JSON object as a single line
FIREBASE_ADMIN_SDK_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
